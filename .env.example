# ===========================================
# PawRes Application Environment Configuration
# ===========================================
# Copy this file to .env and update values as needed.
# Do NOT commit .env to version control (it's in .gitignore).

# --- Admin Account Configuration ---
# Default admin credentials (change these in production!)
# NOTE: Default password policy requires at least 8 characters
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Admin User

# --- Database Configuration (Optional) ---
# Default: app/storage/data/app.db
PAWRES_DB_PATH=

# --- Security Configuration ---
# Login lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Session timeout
SESSION_TIMEOUT_MINUTES=30

# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_HISTORY_COUNT=5

# --- Map Tile Configuration (Optional) ---
MAP_TILE_URL_TEMPLATE=https://a.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png
MAP_TILE_MAX_ZOOM=19
MAP_TILE_HEALTHCHECK_HOST=a.basemaps.cartocdn.com

# --- Runtime/Host Configuration (Optional) ---
# Used for OAuth redirect URL resolution when needed.
# BASE_URL example: http://localhost:8550
BASE_URL=

# If Flet runs on a custom port, set it here.
# Common values: 8550 (desktop), 8000 (web)
FLET_SERVER_PORT=

# --- Google OAuth Configuration (Optional) ---
# Google Sign-In works when EITHER of these is configured:
# 1) Generic pair: GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET
# 2) Mode-specific pairs:
#    - Desktop: GOOGLE_DESKTOP_CLIENT_ID + GOOGLE_DESKTOP_CLIENT_SECRET
#    - Web:     GOOGLE_WEB_CLIENT_ID + GOOGLE_WEB_CLIENT_SECRET

# Generic fallback credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Desktop-specific credentials (recommended for desktop mode)
GOOGLE_DESKTOP_CLIENT_ID=
GOOGLE_DESKTOP_CLIENT_SECRET=

# Web-specific credentials (recommended for web mode)
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=

# Optional explicit redirect URL override
# Example: http://localhost:8550/oauth_callback
GOOGLE_REDIRECT_URL=
